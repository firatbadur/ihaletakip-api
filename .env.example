# ═══════════════════════════════════════════════════════
#  IhaleTakip API — Ortam Değişkenleri (örnek)
#  Kullanım: cp .env.example .env  → değerleri doldur
# ═══════════════════════════════════════════════════════

# ── Django ─────────────────────────────────────────────
DJANGO_SECRET_KEY=degistir-bu-uzun-rastgele-bir-anahtar-olsun
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,api.ihaletakip.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://api.ihaletakip.com

# ── Veritabanı (Docker'da postgres servisi) ───────────
# Yerel geliştirme (SQLite) için bu satırı boş bırak.
DATABASE_URL=postgres://ihale:ihale@db:5432/ihaletakip
POSTGRES_DB=ihaletakip
POSTGRES_USER=ihale
POSTGRES_PASSWORD=ihale

# ── Redis / Celery ─────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── Claude / Anthropic ─────────────────────────────────
# Gerçek anahtar console.anthropic.com'dan alınır; sk-ant-api03-... ile başlar (~100+ karakter).
ANTHROPIC_API_KEY=sk-ant-api03-...
# Güncel modeller: claude-haiku-4-5 (ucuz/hızlı) | claude-sonnet-5 (dengeli) | claude-opus-4-8 (en yüksek kalite).
# Not: claude-sonnet-4-20250514 deprecated (emeklilik 2026-06-15) → kullanmayın.
# Analiz + profil haritası (kalite öncelikli):
CLAUDE_MODEL=claude-sonnet-5
CLAUDE_MAX_TOKENS=3000
# İhale Asistanı sohbeti (sık çalışır → ucuz model, kısa çıktı):
CLAUDE_CHAT_MODEL=claude-haiku-4-5
CLAUDE_CHAT_MAX_TOKENS=1000

# ── Google Sign-In (idToken doğrulama audience'ları) ──
# Virgülle ayrılmış client id listesi (web + iOS + android)
GOOGLE_CLIENT_IDS=254299933947-5na6k5tmaqc2c6dosva9kqakba4ae9hh.apps.googleusercontent.com

# ── Apple Sign-In ──────────────────────────────────────
APPLE_CLIENT_ID=com.envisoft.ihaletakip

# ── Google Cloud Text-to-Speech ────────────────────────
# TTS için servis hesabı JSON yolu (container içi mutlak yol)
GOOGLE_APPLICATION_CREDENTIALS=/app/credentials/tts-service-account.json
TTS_LANGUAGE_CODE=tr-TR
TTS_VOICE_NAME=tr-TR-Standard-A

# ── FCM Push (opsiyonel — bildirimler için) ────────────
# Firebase servis hesabı JSON yolu; boşsa push devre dışı (no-op).
# Anahtarı credentials/fcm-service-account.json'a koy (git-ignore).
FCM_CREDENTIALS=/app/credentials/fcm-service-account.json
FCM_PROJECT_ID=ihale-53fbf

# ── RevenueCat abonelik (Pro) ──────────────────────────
# Secret API key: RevenueCat panel → Project → API keys → "Secret" (sk_... ile başlar).
# app_user_id = str(user.id). Boşsa subscription uçları 502 döner.
REVENUECAT_SECRET_KEY=sk_...
REVENUECAT_PROJECT_ID=proj3e35bc67
REVENUECAT_ENTITLEMENT=pro
# Webhook doğrulama: RС panel → Integrations → Webhooks → Authorization header
# alanına AYNI değeri yaz. Güçlü rastgele bir string üret (secrets.token_urlsafe).
REVENUECAT_WEBHOOK_AUTH=degistir-guclu-rastgele-string

# ── Bildirim pacing (kullanıcıyı bombalamamak için) ────
# Sessiz saatler (yerel): bu aralıkta push atılmaz, uygulama-içi satır yazılır.
NOTIF_QUIET_START_HOUR=22
NOTIF_QUIET_END_HOUR=7
# Kullanıcı başına günlük en fazla push sayısı.
NOTIF_DAILY_CAP=4
# İki push arası minimum dakika.
NOTIF_MIN_GAP_MINUTES=30

# ── EKAP veri toplama ──────────────────────────────────
EKAP_BASE_URL=https://ekapv2.kik.gov.tr
# AES-192 imzalama anahtarı (mobil calls.js ile AYNI olmalı)
EKAP_SIGNING_KEY=Qm2LtXR0aByP69vZNKef4wMJ
EKAP_MIN_INTERVAL_MS=1000
EKAP_TIMEOUT=30
EKAP_MAX_RETRIES=4
EKAP_RECENT_DAYS=3
EKAP_BACKFILL_YEARS=5
EKAP_REFRESH_YEARS=1

# ── İlk admin kullanıcı (entrypoint otomatik oluşturur) ─
# ⚠️ Admin paneli internete açıktır — güçlü, benzersiz bir parola kullan.
DJANGO_SUPERUSER_USERNAME=firat
DJANGO_SUPERUSER_PASSWORD=degistir-guclu-bir-parola
DJANGO_SUPERUSER_EMAIL=firat@ihaletakip.local
